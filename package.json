{
  "name": "cisco-wlc-mcp",
  "version": "0.1.3",
  "description": "MCP server for Cisco Catalyst 9800 WLC (RESTCONF, read-only)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cisco-wlc-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepack": "npm run build",
    "release": "release-script",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.eslint.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "axios": "^1.7.9",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "24.13.3",
    "typescript": "5.9.3",
    "@alcalzone/release-script": "5.2.1",
    "@alcalzone/release-script-plugin-license": "5.2.0",
    "@alcalzone/release-script-plugin-manual-review": "5.2.0",
    "@eslint/js": "10.0.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.9.5",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
